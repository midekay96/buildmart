{
  "name": "buildmart",
  "version": "1.0.0",
  "description": "BuildMart - Building Materials Marketplace (Full Stack)",
  "private": true,
  "scripts": {
    "install-all": "npm install && cd frontend && npm install && cd ../backend && npm install && cd ..",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm start",
    "dev:backend": "cd backend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "start": "npm run dev:backend",
    "test": "echo \"Run tests in individual packages\""
  },
  "keywords": ["marketplace", "building-materials", "ecommerce"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.1"
  }
}
