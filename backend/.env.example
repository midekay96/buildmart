# BuildMart Backend - Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=buildmart_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Auth
JWT_SECRET=replace_with_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=buildmart2026

# Paystack (https://dashboard.paystack.com/#/settings/developers)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Support contacts
SUPPORT_EMAIL=support@buildmart.ng
SUPPORT_WHATSAPP=+2348012345678

# Optional: Cloudinary (product image upload)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
